# ==================================
# Buzzy Today Environment Variables
# ==================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# --- Firebase ---
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_SERVICE_ACCOUNT_KEY=    # Path to JSON key file for admin SDK

# --- OpenAI ---
OPENAI_API_KEY=

# --- Google Sheets (for sync scripts) ---
GOOGLE_SHEETS_SERVICE_ACCOUNT=   # Path to service account JSON
BUZZY_CATEGORIES_SHEET_ID=
ARTICLE_SOURCING_SHEET_ID=
RSS_MASTER_SHEET_ID=
TOPIC_TAG_MASTER_SHEET_ID=

# --- AWS S3 (existing image storage) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# --- SendGrid ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@buzzytoday.com

# --- Pixabay ---
PIXABAY_API_KEY=

# --- Newsblur ---
NEWSBLUR_USERNAME=
NEWSBLUR_PASSWORD=

# --- Seed Data ---
USE_SEED_DATA=true              # Set to 'false' to disable seed data and require Firestore

# --- App Config ---
NODE_ENV=development
API_PORT=3001
API_HOST=0.0.0.0
LOG_LEVEL=debug

# --- Web App ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
