rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if user is accessing their own data
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper: Check if user has admin role (custom claim)
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isAdmin();

      // User subcollections
      match /bookmarks/{bookmarkId} {
        allow read, write: if isOwner(userId);
      }

      match /followed_tags/{tagId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId);
      }

      match /followed_categories/{categoryId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId);
      }

      match /interest_graph/{entryId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId);
      }

      match /signals/{signalId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
      }
    }

    // Articles collection — public read, admin write
    match /articles/{articleId} {
      allow read: if true;
      allow write: if isAdmin();

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
        allow delete: if isAdmin();
      }
    }

    // Topic tags — public read, admin write
    match /topic_tags/{tagId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Category tags — public read, admin write
    match /category_tags/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // RSS sources — admin only
    match /rss_sources/{sourceId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Signals collection — authenticated create, admin read
    match /signals/{signalId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
    }

    // Suggested tags — admin only
    match /suggested_tags/{tagId} {
      allow read, write: if isAdmin();
    }

    // Buzzwords — admin only
    match /buzzwords/{buzzwordId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Daily digests — public read, admin write
    match /daily_digests/{digestId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User reports — authenticated create, admin read
    match /user_reports/{reportId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
    }

    // AI prompt config — admin only
    match /ai_config/{configId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Publishing quotas — admin only
    match /publishing_quotas/{quotaId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
